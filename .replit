modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Enrichment Scraper"

[[workflows.workflow]]
name = "Enrichment Scraper"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/enrichment-scraper run dev"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 8008

[[ports]]
localPort = 8084
externalPort = 8099

[[ports]]
localPort = 18115
externalPort = 3001

[[ports]]
localPort = 18116
externalPort = 4200

[[ports]]
localPort = 18153
externalPort = 5000

[[ports]]
localPort = 18285
externalPort = 3003

[[ports]]
localPort = 19255
externalPort = 80

[[ports]]
localPort = 22742
externalPort = 3000

[nix]
channel = "stable-25_05"
packages = ["fontconfig", "ghostscript", "glib", "harfbuzz", "libxcrypt", "pango", "xcodebuild", "zlib"]

